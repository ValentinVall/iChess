# Docker Environment Variables
# Copy this to .env for Docker setup

# PostgreSQL
DB_NAME=ichess
DB_USER=postgres
DB_PASSWORD=postgres

# Node Environment
NODE_ENV=development

# Backend
PORT=3000

# Apple Sign In
APPLE_KEY_ID=your-key-id
APPLE_TEAM_ID=your-team-id
APPLE_BUNDLE_ID=com.ichess.app
APPLE_PRIVATE_KEY_PATH=./private_key.pem

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Frontend
VITE_API_URL=http://backend:3000/api
VITE_APP_NAME=iChess Premium
